# No environment variables are required for the free core workflow.

# Optional AI provider. Deterministic analysis remains available without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional durable analysis cache. Local development uses the filesystem fallback.
DATABASE_URL=
CODEPROOF_CACHE_DIR=.data/analysis-cache

# Optional local candidate database location.
CODEPROOF_DB_PATH=.data/codeproof.db

# Optional access gate. When set, uploading requires HTTP Basic auth with this
# value as the password: the /analyze page and every mutating request are
# protected, while browsing stays open so a public demo still works.
# /api/health always stays open for deployment monitoring.
# Leave empty for the zero-config local demo. Only enable behind HTTPS.
CODEPROOF_ACCESS_CODE=

# Set to true to ALSO require the access code for reading candidate records.
# Use this on any deployment holding real (non-demo) candidate data, otherwise
# stored dossiers are readable by anyone with the URL.
CODEPROOF_PROTECT_ALL=
