# No environment variables are required for the free core workflow.

# Optional AI provider. Deterministic analysis remains available without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional durable analysis cache. Local development uses the filesystem fallback.
DATABASE_URL=
CODEPROOF_CACHE_DIR=.data/analysis-cache

# Optional local candidate database location.
CODEPROOF_DB_PATH=.data/codeproof.db
