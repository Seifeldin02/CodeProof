# No environment variables are required for the free core workflow.

# Optional AI provider. Deterministic analysis remains available without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Durable production database for accounts, candidates, requirements, and cache.
# Required on serverless/ephemeral hosts such as Vercel. Local development uses SQLite.
DATABASE_URL=
POSTGRES_URL=
CODEPROOF_CACHE_DIR=.data/analysis-cache

# Optional local candidate database location.
CODEPROOF_DB_PATH=.data/codeproof.db

# Signs session cookies. REQUIRED in production: without it each instance
# generates its own key, so sessions break across restarts and instances.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CODEPROOF_SESSION_SECRET=

# Public account creation is enabled by default. Set to false only for a closed pilot.
CODEPROOF_ALLOW_SIGNUP=
