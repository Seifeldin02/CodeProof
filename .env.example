# No environment variables are required for the free core workflow.

# Optional AI provider. Deterministic analysis remains available without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional durable analysis cache. Local development uses the filesystem fallback.
DATABASE_URL=
CODEPROOF_CACHE_DIR=.data/analysis-cache

# Optional local candidate database location.
CODEPROOF_DB_PATH=.data/codeproof.db

# Signs session cookies. REQUIRED in production: without it each instance
# generates its own key, so sessions break across restarts and instances.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CODEPROOF_SESSION_SECRET=

# Set to true to ALSO require sign-in to READ candidate records. Uploading
# always requires an account. Use this on any deployment holding real
# (non-demo) candidates, otherwise stored dossiers are readable by anyone.
CODEPROOF_PROTECT_ALL=

# Set to true to keep registration open for teammates. Left unset, registration
# closes automatically once the first account claims the workspace.
CODEPROOF_ALLOW_SIGNUP=
