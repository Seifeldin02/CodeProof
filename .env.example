# No environment variables are required for the free core workflow.

# Optional AI provider. Deterministic analysis remains available without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Optional durable analysis cache. Local development uses the filesystem fallback.
DATABASE_URL=
CODEPROOF_CACHE_DIR=.data/analysis-cache

# Optional local candidate database location.
CODEPROOF_DB_PATH=.data/codeproof.db

# Optional access gate for public deployments. When set, the whole workspace
# (pages and API) requires HTTP Basic auth with this value as the password, so
# candidate dossiers are not world-readable on a public URL. /api/health stays
# open for deployment monitoring. Leave empty for the local zero-config demo.
# Only enable behind HTTPS.
CODEPROOF_ACCESS_CODE=
