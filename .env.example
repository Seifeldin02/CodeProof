# Optional. Public GitHub requests work without a token but have lower rate limits.
GITHUB_TOKEN=

# Optional. Without this key CodeProof returns factual deterministic analysis only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Recommended for persistent production caching, including Replit deployments.
DATABASE_URL=

# Optional local-development fallback when DATABASE_URL is not set.
CODEPROOF_CACHE_DIR=.data/analysis-cache
